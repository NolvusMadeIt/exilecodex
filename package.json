{
  "name": "exilecodex",
  "version": "2.1.8-alpha",
  "description": "ExileCodex — companion overlay for Path of Exile 2",
  "author": "NolvusMadeIt",
  "private": true,
  "main": "app/client/electron/main.cjs",
  "scripts": {
    "test": "node --test test/overlay-bootstrap.test.cjs test/log-parse.test.cjs test/site-landing.test.cjs test/release-contract.test.cjs test/plugin-identity.test.cjs test/plugin-update-callback-contract.test.cjs test/onboarding-contract.test.cjs test/overlay-bounds.test.cjs test/bounded-overlay-contract.test.cjs test/overlay-controller-smoke.test.cjs test/pob-updater.test.cjs test/build-planner-loader-contract.test.cjs test/bump-versions.test.cjs",
    "postinstall": "node scripts/copy-vendor.cjs",
    "dev": "http-server -p 4400 -c-1 .",
    "app": "electron .",
    "dist": "electron-builder --win nsis --x64",
    "dist:portable": "electron-builder --win portable --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.exilecodex.app",
    "productName": "ExileCodex",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "package.json",
      "!**/*.map",
      "!concept1/**",
      "!.env.local"
    ],
    "extraMetadata": {
      "main": "app/client/electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "app/media/brand/logo_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ExileCodex-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NolvusMadeIt",
        "repo": "exilecodex",
        "releaseType": "prerelease"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "fengari-web": "^0.1.4",
    "http-server": "^14.1.1",
    "monaco-editor": "^0.52.2"
  }
}
