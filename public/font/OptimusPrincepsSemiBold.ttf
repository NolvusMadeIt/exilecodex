  <!-- Modal for example images -->
  <div class="modal-overlay" id="imageModal">
    <div class="modal-content">
      <img id="modalImage" src alt="Example image">
    </div>
  </div>

  <script>
    // Modal functionality for example images
    document.addEventListener('DOMContentLoaded', function() {
      const modal = document.getElementById('imageModal');
      const modalImage = document.getElementById('modalImage');
      const exampleImages = document.querySelectorAll('.example-image');
      let currentImageIndex = 0;

      // Open modal when clicking on example images
      exampleImages.forEach(function(img, index) {
        img.addEventListener('click', function(e) {
          e.preventDefault();
          currentImageIndex = index;
          modalImage.src = this.src;
          modal.classList.add('active');
          document.body.style.overflow = 'hidden'; // Prevent scrolling
        });
      });

      // Handle modal clicks
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          // Click on overlay - close modal
          closeModal();
        } else if (e.target === modalImage) {
          // Click on image - show next image
          showNextImage();
        }
      });

      // Close modal with Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          closeModal();
        } else if (e.key === 'ArrowRight' && modal.classList.contains('active')) {
          showNextImage();
        } else if (e.key === 'ArrowLeft' && modal.classList.contains('active')) {
          showPreviousImage();
        }
      });

      function showNextImage() {
        currentImageIndex = (currentImageIndex + 1) % exampleImages.length;
        modalImage.src = exampleImages[currentImageIndex].src;
      }

      function showPreviousImage() {
        currentImageIndex = (currentImageIndex - 1 + exampleImages.length) % exampleImages.length;
        modalImage.src = exampleImages[currentImageIndex].src;
      }

      function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = ''; // Restore scrolling
      }
    });
  </script>
